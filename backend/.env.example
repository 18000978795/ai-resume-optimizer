# ═══════════════════════════════════════
# AI 简历优化助手 — 环境变量配置
# 复制此文件为 .env 并修改配置
# ═══════════════════════════════════════

# 服务端口
PORT=3000

# ─── MySQL 数据库（可选，不配置则使用内存存储）───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ai_resume

# ─── AI API（后续接入使用）───
AI_ENABLED=false
AI_API_KEY=sk-your-api-key-here
AI_API_URL=https://api.anthropic.com/v1/messages
